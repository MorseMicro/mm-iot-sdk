source $SCRIPT_DIR/config.sh

MORSE_ARM_TOOLCHAIN_VERSION=14.2.1-1.1
MORSE_ARM_TOOLCHAIN_DESTINATION_DIRECTORY=$MORSE_TOOLS_DIR
MORSE_ARM_TOOLCHAIN_DIR=$MORSE_ARM_TOOLCHAIN_DESTINATION_DIRECTORY/xpack-arm-none-eabi-gcc-$MORSE_ARM_TOOLCHAIN_VERSION
MORSE_ARM_TOOLCHAIN_TAR=xpack-arm-none-eabi-gcc-$MORSE_ARM_TOOLCHAIN_VERSION-darwin-$MORSE_ARCH.tar.gz
MORSE_ARM_TOOLCHAIN_TAR_SHA=$MORSE_ARM_TOOLCHAIN_TAR.sha

[[ "${VARS_ONLY:-0}" == "1" ]] && return

if [ -d "$MORSE_ARM_TOOLCHAIN_DIR" ]
then
    echo -e "\033[36mToolchain directory $MORSE_ARM_TOOLCHAIN_DIR already exists. Skipping installation.\033[0m"
else
    echo -e "\033[32mDownloading and extracting ARM toolchain (xPack).\033[0m"
    $DRYRUNCMD curl -L --progress-bar https://github.com/xpack-dev-tools/arm-none-eabi-gcc-xpack/releases/download/v$MORSE_ARM_TOOLCHAIN_VERSION/$MORSE_ARM_TOOLCHAIN_TAR_SHA -o $MORSE_ARM_TOOLCHAIN_TAR_SHA
    $DRYRUNCMD curl -L --progress-bar https://github.com/xpack-dev-tools/arm-none-eabi-gcc-xpack/releases/download/v$MORSE_ARM_TOOLCHAIN_VERSION/$MORSE_ARM_TOOLCHAIN_TAR -o $MORSE_ARM_TOOLCHAIN_TAR
    $DRYRUNCMD shasum -a 256 -c $MORSE_ARM_TOOLCHAIN_TAR_SHA || (echo -e "\033[31mDownload corrupted, retry. \033[0m" && exit 1)
    $DRYRUNCMD $SUDO tar -xf $MORSE_ARM_TOOLCHAIN_TAR -C $MORSE_ARM_TOOLCHAIN_DESTINATION_DIRECTORY
fi
